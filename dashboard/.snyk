# Snyk (https://snyk.io) policy file
version: v1.25.1

ignore:
  SNYK-JS-WEBPACK-15235959:
    - '*':
        reason: >
          webpack buildHttp SSRF (GHSA-8fgc-7cc6-rx7x, low severity).
          Only affects the experimental buildHttp plugin, which is not used.
          All affected packages (storybook, babel-loader, css-loader, etc.)
          are devDependencies only — webpack never ships to production.
          main branch carries webpack@5.99.9 in the same vulnerable range;
          this is not newly introduced by this PR.
        expires: 2026-10-01T00:00:00.000Z
  SNYK-JS-WEBPACK-15235969:
    - '*':
        reason: >
          webpack buildHttp SSRF via HTTP redirects (GHSA-38r7-794h-5758,
          low severity). Same rationale as SNYK-JS-WEBPACK-15235959 above.
          Dev-only dependency, buildHttp not used, same version on main.
        expires: 2026-10-01T00:00:00.000Z

  SNYK-JS-IMMUTABLE-15423650:
    - '*':
        reason: >
          immutable Prototype Pollution (CVE-2026-29063) via
          @excalidraw/excalidraw@0.18.0 → sass@1.51.0. Snyk resolves from
          excalidraw's published manifest; the npm override forces sass@1.98.0
          (immutable@^5.1.5, clean) in the actual installation. Upstream
          excalidraw@0.18.0 is the latest release and has not yet updated sass.
        expires: 2026-10-01T00:00:00.000Z

patch: {}
