  "scripts": {
    "dev": "npx concurrently -n \"WEB,DISPATCH\" -c \"cyan,magenta\" \"npm run dev:web\" \"npm run dev:dispatcher\"",
    "dev:web": "bash -c 'set -a; [ -f ../.env ] && . ../.env; [ -f ./.env.local ] && . ./.env.local; set +a; for v in PLEXUS_API_URL PLEXUS_API_KEY PLEXUS_ACCOUNT_KEY; do if [ -z \"${!v:-}\" ]; then echo \"Missing $v for dev:web\" >&2; exit 1; fi; done; export NEXT_PUBLIC_PLEXUS_API_URL=\"$PLEXUS_API_URL\"; export NEXT_PUBLIC_PLEXUS_API_KEY=\"$PLEXUS_API_KEY\"; export NEXT_PUBLIC_PLEXUS_API_REGION=\"${PLEXUS_API_REGION:-${NEXT_PUBLIC_PLEXUS_API_REGION:-}}\"; export NEXT_PUBLIC_PLEXUS_ACCOUNT_KEY=\"$PLEXUS_ACCOUNT_KEY\"; NEXT_TYPESCRIPT_CHECK=0 next dev'",
    "dev:dispatcher": "bash -c 'set -a; [ -f ../.env ] && . ../.env; [ -f ./.env.local ] && . ./.env.local; set +a; for v in PLEXUS_API_URL PLEXUS_API_KEY PLEXUS_ACCOUNT_KEY OPENAI_API_KEY; do if [ -z \"${!v:-}\" ]; then echo \"Missing $v for dev:dispatcher\" >&2; exit 1; fi; done; PLEXUS_FETCH_SCHEMA_FROM_TRANSPORT=false PLEXUS_DISPATCH_MODE=local /Users/ryan/miniconda3/bin/python -m plexus.cli command dispatcher --interval 0.5 --loglevel INFO'",
    "build": "next build",
    "build:fast": "NEXT_TYPESCRIPT_CHECK=0 next build",
    "start": "next start",
    "lint": "next lint --no-cache",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "test-storybook",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:storybook": "test-storybook",
    "typecheck": "tsc --noEmit --pretty --diagnostics",
    "typecheck:profile": "tsc --noEmit --generateTrace .ts-trace",
    "test-storybook:ci": "npm run build-storybook --quiet && npx concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"npx http-server storybook-static --port 6007 --silent\" \"npx wait-on tcp:6007 && npm run test-storybook -- --url http://localhost:6007\"",
    "ci:typecheck": "npm run typecheck",
    "ci:unit": "npm run test:coverage",
    "ci:storybook": "npm run test-storybook:ci",
    "ci": "npm run ci:typecheck && npm run ci:unit && npm run ci:storybook",
    "ci:watch": "npx concurrently -k -n \"TYPE,TEST\" -c \"cyan,green\" \"tsc --noEmit --watch --pretty\" \"jest --watchAll --coverage\"",
    "postinstall": "node scripts/patch-next-config.js"
  },
